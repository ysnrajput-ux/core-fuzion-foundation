rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User-scoped uploads: /users/{uid}/...
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
