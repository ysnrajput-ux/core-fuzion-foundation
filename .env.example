# ──────────────────────────────────────────────────────────────
# Fuzion Coaching Institute — environment variables
# ──────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and paste your Firebase project
# credentials from the Firebase Console:
#   Project settings → General → Your apps → SDK setup and configuration
#
# NEVER commit `.env.local`. It is git-ignored.
# ──────────────────────────────────────────────────────────────

# App
VITE_APP_NAME="Fuzion Coaching Institute"
VITE_APP_ENV="development"

# Firebase — paste your project credentials here
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
